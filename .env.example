# =============================================================================
# Environment Variables — copy to .env and fill in your values
# NEVER commit .env — it is gitignored
# =============================================================================

# --- AI Backends (BYOK — bring your own key) ---
# At least one is required for AI features
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GROQ_API_KEY=your-groq-key-here
OPENAI_API_KEY=your-openai-key-here

# Fallback key (used if backend-specific key is not set)
AI_API_KEY=your-fallback-key-here

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Azure (production only) ---
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id

# --- Feature Flags ---
# Override feature flags via env vars (prefix: FF_)
# FF_NEW_FEATURE=true

# --- Observability ---
# LOG_LEVEL=info
# FLIGHT_RECORDER_CAPACITY=3000
